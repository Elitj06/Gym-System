# ===========================================
# Gym-System - Variáveis de Ambiente (exemplo)
# ===========================================
# Copie este ficheiro para .env e preencha com os seus valores.
# NUNCA faça commit do ficheiro .env (contém dados sensíveis).

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gym_db
REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://localhost:27017/gym_analytics

# API (Backend)
PORT=3000
NODE_ENV=development
JWT_SECRET=seu_jwt_secret_aqui
API_KEY=sua_api_key_aqui

# AI Vision Service
AI_VISION_URL=http://localhost:5000
CONFIDENCE_THRESHOLD=0.7
FLASK_ENV=development

# AWS (opcional, para produção)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=gym-ai-uploads

# Notificações (opcional)
FIREBASE_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

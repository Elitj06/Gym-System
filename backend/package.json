{
  "name": "gym-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for Gym AI Management System",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "ts-node src/database/migrate.ts",
    "seed": "ts-node src/database/seed.ts",
    "docker:build": "docker build -t gym-ai-backend .",
    "docker:run": "docker run -p 3000:3000 gym-ai-backend"
  },
  "keywords": [
    "gym",
    "ai",
    "fitness",
    "management",
    "pose-detection"
  ],
  "author": "Elite Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.0",
    "redis": "^4.6.7",
    "mongodb": "^5.6.0",
    "mongoose": "^7.3.0",
    "jsonwebtoken": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.8.0",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0",
    "winston": "^3.9.0",
    "axios": "^1.4.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.1",
    "joi": "^17.9.2",
    "compression": "^1.7.4",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "nodemailer": "^6.9.3",
    "firebase-admin": "^11.9.0",
    "aws-sdk": "^2.1400.0",
    "bull": "^4.11.3",
    "cron": "^2.3.1",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.7",
    "@types/compression": "^1.7.2",
    "@types/uuid": "^9.0.2",
    "@types/nodemailer": "^6.4.8",
    "@types/jest": "^29.5.2",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "nodemon": "^2.0.22",
    "eslint": "^8.43.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
